# DevContainer shortcut — runs devcontainer up from current directory with dotfiles
unalias devup 2>/dev/null
function devup {
    local args=(
        up
        --workspace-folder .
        --dotfiles-repository https://github.com/Maladus/dotfiles.git
        --dotfiles-install-command install.sh
    )
    [[ -n $GITHUB_TOKEN ]] && args+=(--remote-env "GITHUB_TOKEN=$GITHUB_TOKEN")
    if [[ -n $SSH_AUTH_SOCK ]]; then
        args+=(--mount "type=bind,source=${SSH_AUTH_SOCK},target=/tmp/host-ssh-auth.sock")
        args+=(--remote-env "SSH_AUTH_SOCK=/tmp/host-ssh-auth.sock")
    fi
    devcontainer "${args[@]}"
}

# Find running dev container (DevPod or VS Code) that mounts current directory
_devcode_find_container() {
    local pwd="${PWD}"
    local c devpod_c vscode_c

    # Try DevPod container first
    for c in $(docker ps -q --filter "label=devpod.user"); do
        if docker inspect "$c" --format '{{json .Mounts}}' | grep -qF "\"Source\":\"$pwd\""; then
            devpod_c="$c"
            break
        fi
    done

    # Try VS Code dev container
    for c in $(docker ps -q --filter "label=devcontainer.config_file"); do
        if docker inspect "$c" --format '{{json .Config.Labels}}' | grep -qF "\"devcontainer.config_file\":\"$pwd/.devcontainer/devcontainer.json\""; then
            vscode_c="$c"
            break
        fi
    done

    if [[ -n "$devpod_c" ]]; then
        echo "devpod:$devpod_c"
    elif [[ -n "$vscode_c" ]]; then
        echo "vscode:$vscode_c"
    fi
}

# Docker exec into container that mounts the current directory
# Works with both DevPod and VS Code dev containers
devdock() {
    local result="$(_devcode_find_container)"
    if [[ -z "$result" ]]; then
        echo "No running dev container found for ${PWD}" >&2
        return 1
    fi
    local cid="${result#*:}"
    # Use 'vscode' user (standard for mcr.microsoft.com/devcontainers images)
    # Fall back to default (root) if that doesn't exist
    local cont_user=vscode
    if ! docker exec "$cid" id vscode >/dev/null 2>&1; then
        cont_user=root
    fi
    # Derive workspace path from the mount that matches PWD
    local cont_workdir
    local pwd_="$PWD"
    # Use -json to avoid Go template concatenating multiple mount matches
    cont_workdir=$(docker inspect "$cid" --format '{{json .Mounts}}' 2>/dev/null \
        | python3 -c "
import json, sys
mounts = json.loads(sys.stdin.read())
for m in mounts:
    if m.get('Source') == '$pwd_':
        print(m['Destination'])
        break
" 2>/dev/null)
    [[ -z "$cont_workdir" ]] && cont_workdir="/workspaces/$(basename "$PWD")"
    docker exec -it -u "$cont_user" -w "$cont_workdir" -e TERM="$TERM" ${SSH_AUTH_SOCK:+-e SSH_AUTH_SOCK="$SSH_AUTH_SOCK"} "$cid" /bin/zsh
}

