{
  "defaultProvider": "ollama-cloud",
  "defaultThinkingLevel": "medium",
  "hideThinkingBlock": true,
  "theme": "dark",
  "quietStartup": false,
  "collapseChangelog": false,
  "terminal": {
    "showImages": true,
    "imageWidthCells": 60
  },
  "images": {
    "autoResize": true,
    "blockImages": false
  },
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "timeoutMs": 3600000,
      "maxRetries": 0,
      "maxRetryDelayMs": 60000
    }
  },
  "packages": [
    "npm:pi-rtk-optimizer"
  ],
  "prompts": [
    "prompts"
  ]
}